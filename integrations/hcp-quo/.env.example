# Copy this file to .env and fill in real values. NEVER commit .env.

# HouseCall Pro MAX API key
HCP_API_KEY=

# Quo (OpenPhone) API key
QUO_API_KEY=

# HMAC signing secret — shown by HCP the first time you register the webhook.
# Leave blank for local testing; required in production.
HCP_WEBHOOK_SECRET=

# MongoDB connection string (required). For Atlas, the free M0 tier is plenty.
# Example:
# MONGO_URI=mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=

# Optional: override the database name
# MONGO_DB_NAME=hcp_quo

# Optional: override defaults
# HCP_BASE_URL=https://api.housecallpro.com
# QUO_BASE_URL=https://api.openphone.com/v1
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
